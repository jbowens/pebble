----
index-block-decoder
 └── index block header
      ├── columnar block header
      │    ├── 00-01: x 01       # version 1
      │    ├── 01-03: x 0200     # 2 columns
      │    ├── 03-07: x 06000000 # 6 rows
      │    ├── 07-08: b 00000010 # col 0: uint
      │    ├── 08-12: x 11000000 # col 0: page start 17
      │    ├── 12-13: b 00000010 # col 1: uint
      │    └── 13-17: x 1e000000 # col 1: page start 30
      ├── data for column 0 (uint)
      │    ├── 17-18: x 02   # encoding: 2b
      │    ├── 18-20: x 6400 # data[0] = 100
      │    ├── 20-22: x cb00 # data[1] = 203
      │    ├── 22-24: x 2701 # data[2] = 295
      │    ├── 24-26: x bf03 # data[3] = 959
      │    ├── 26-28: x e803 # data[4] = 1000
      │    └── 28-30: x 1a04 # data[5] = 1050
      ├── data for column 1 (uint)
      │    ├── 30-31: x 02   # encoding: 2b
      │    ├── 31-32: x 00   # padding (aligning to 16-bit boundary)
      │    ├── 32-34: x 0a00 # data[0] = 10
      │    ├── 34-36: x 2300 # data[1] = 35
      │    ├── 36-38: x 8c00 # data[2] = 140
      │    ├── 38-40: x 9b00 # data[3] = 155
      │    ├── 40-42: x 0401 # data[4] = 260
      │    ├── 42-44: x 3c01 # data[5] = 316
      │    └── 44-46: x 4b01 # data[6] = 331
      └── 46-47: x 00 # block padding byte

